# PCF Insight Dashboard — environment variables example
# Copy this file to `.env` and replace placeholders with your real Supabase values.
# `.env` is gitignored, so real credentials never leave your machine.

# ─────────────────────────────────────────────────────────────
# DATABASE (Supabase Postgres)
# ─────────────────────────────────────────────────────────────
#
# 가장 단순한 설정: Supabase의 5432 직결 URL을 그대로 사용한다.
# (Supabase 대시보드 → Project → Connect → "Connection string" → URI 형식)
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/postgres"

# (선택) pgBouncer pooler를 함께 쓰고 싶다면
#   1) DATABASE_URL을 pooler URL(6543 포트)로 바꾸고 끝에
#      `?pgbouncer=true&connection_limit=1`을 붙인다.
#   2) DIRECT_URL을 아래처럼 추가해 db push/seed가 직결 URL을 사용하도록 한다.
#   3) schema.prisma 의 datasource 블록에 `directUrl = env("DIRECT_URL")`을 다시 활성화한다.
#
# DIRECT_URL="postgresql://USER:PASSWORD@HOST:5432/postgres"
