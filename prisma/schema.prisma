// PCF Insight Dashboard - Prisma schema
//
// 활동 데이터(`ActivityRecord`)와 배출계수(`EmissionFactor`)를 분리해 보관한다.
// 활동 레코드에는 계산된 배출량이나 계수 스냅샷을 저장하지 않는다.
// 배출계수는 `effectiveFrom`/`effectiveTo` 기간을 가져, 동일 항목에 대해
// 시점이 다른 여러 버전을 동시에 보관할 수 있다.
//
// 활동 발생일과 effective 기간을 비교해 "활성" 계수를 고르므로,
// 배출량은 활동 레코드를 수정하지 않고도 계수 업데이트만으로 재계산된다.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  // Supabase에서는 5432 직결 URL을 그대로 넣으면 런타임과 DDL 모두 한 변수로 충분하다.
  // 운영 트래픽이 커서 pgBouncer pooler를 분리하고 싶다면
  // `directUrl = env("DIRECT_URL")`을 추가하고 .env에 `DIRECT_URL`을 함께 정의한다.
  url = env("DATABASE_URL")
}

model EmissionFactor {
  id String @id @default(cuid())

  /// 'electricity' | 'material' | 'transport'
  activityType String
  /// 활동 description과 매칭되는 계수 이름 (예: "한국전력", "플라스틱 1").
  name String

  /// 활동량 1단위당 kgCO2e.
  factor     Float
  /// 'kgCO2e/kWh' | 'kgCO2e/kg' | 'kgCO2e/ton-km'
  factorUnit String

  /// 'scope1' | 'scope2' | 'scope3'
  scope String

  /// 사람이 읽기 쉬운 버전 태그 (예: "2025.1").
  version String

  /// 이 계수가 적용되기 시작하는 날짜(포함).
  effectiveFrom DateTime
  /// 적용 종료 날짜(포함, null이면 현재까지 유효).
  effectiveTo DateTime?

  sourceLabel String?
  note        String?

  createdAt DateTime @default(now())

  // 활성 계수 조회를 자주 수행하므로 검색 키 인덱스를 미리 둔다.
  @@index([activityType, name, effectiveFrom])
}

model ActivityRecord {
  id String @id @default(cuid())

  productId String

  activityType String
  description  String

  amount Float
  unit   String

  activityDate DateTime

  createdAt DateTime @default(now())

  @@index([productId, activityDate])
}
